// ============================================================
// HandoffOverlay — DreamCatcher → DreamStudio morph animation
// Phases: strip-ui → morph-nodes → new-env → project-card
// ============================================================

// Node type → block color (matches canvas node colors)
const NODE_TYPE_COLORS = {
  process: "#7C3AED",
  subprocess: "#2563EB",
  role: "#16A34A",
  system: "#92400E"
};

function HandoffOverlay({ phase, nodes }) {
  // phase: "strip-ui" | "morph-nodes" | "new-env" | "project-card"
  const isNewEnv = phase === "new-env" || phase === "project-card";
  const isProjectCard = phase === "project-card";
  const isMorphed = phase === "morph-nodes" || isNewEnv;

  // Build a representative set of blocks from live node types
  const nodeTypes = nodes.length ?
  nodes.map((n) => n.type) :
  ["process", "system", "subprocess", "role", "subprocess", "process", "system", "role"];

  return (
    <div className={`handoff-overlay ${phase}`}>
      {/* Dark dot-grid background — always present, fades in on new-env */}
      <div className="handoff-bg" />

      {/* Central content */}
      <div className="handoff-center">
        {isNewEnv &&
        <div className="handoff-header">
            <span className="handoff-done-label">Your dream session is done</span>
            <div className="handoff-brand-pill">
              <img src="assets/icon-catcher.svg" alt="" className="handoff-brand-icon" />
              <span>DreamCatcher</span>
            </div>
          </div>
        }

        {/* Project card with morph'd node blocks inside */}
        <div className={`handoff-card ${isProjectCard ? "revealed" : ""}`}>
          {/* Node blocks strip — colored bars representing the ontology */}
          <div className="handoff-blocks">
            {nodeTypes.slice(0, 12).map((type, i) =>
            <div
              key={i}
              className="handoff-block"
              style={{
                background: NODE_TYPE_COLORS[type] || "#4B5563",
                width: `${48 + Math.sin(i * 1.7) * 20}px`,
                animationDelay: `${i * 0.06}s`
              }} />

            )}
          </div>

          {isProjectCard &&
          <div className="handoff-card-meta">
              <div className="handoff-project-name">Order Fulfilment Discovery Company:<br />E-Commerce Platform Redesign</div>
              <div className="handoff-company">TechCorp</div>
            </div>
          }
        </div>

        {isProjectCard &&
        <div className="handoff-converting">
            <svg className="handoff-spinner" viewBox="0 0 24 24" fill="none" width="14" height="14">
              <circle cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="2" strokeDasharray="40 20" strokeLinecap="round" />
            </svg>
            Converting ...
          </div>
        }
      </div>
    </div>);

}

window.HandoffOverlay = HandoffOverlay;